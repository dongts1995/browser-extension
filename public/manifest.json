{
  "manifest_version": 3,
  "name": "Slides Extension",
  "version": "1.0",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.portals.now/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}