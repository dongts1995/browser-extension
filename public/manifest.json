{
  "manifest_version": 3,
  "name": "Slides Extension",
  "version": "1.0",
  "oauth2": {
    "client_id": "66081486935-ikq6aiid7lf3piu5rtluduc4tepb1jfb.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/presentations"
    ]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "identity",
    "webNavigation"
  ],
  "host_permissions": [
    "https://docs.google.com/presentation/*",
    "https://api.portals.now/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/presentation/*"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ]
}