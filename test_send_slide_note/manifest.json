{
    "manifest_version": 3,
    "name": "Slide Sender",
    "version": "1.0",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.portals.now/*",
        "wss://api.portals.now/*",
        "https://lh7-us.googleusercontent.com/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}